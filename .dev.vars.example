# Local environment variables for Cloudflare Workers
# This file is automatically read by 'wrangler dev'
#
# INSTRUCTIONS:
# 1. Copy this file to '.dev.vars' (without .example)
# 2. Do not edit this file, edit the copy
#
# Command: cp .dev.vars.example .dev.vars

# Master key for encrypting credentials in KV
# You can generate one with: openssl rand -base64 32
MASTER_ENCRYPTION_KEY="YOUR_BASE64_KEY_HERE"
